<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <TargetFramework>net9.0-windows</TargetFramework>
    <OutputType>Exe</OutputType>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>disable</Nullable>
    <IsPackable>false</IsPackable>
    <UseAppHost>false</UseAppHost>
    <HelEngineRoot Condition="'$(HelEngineRoot)' == ''">..\..\helengine</HelEngineRoot>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="$(HelEngineRoot)\engine\helengine.baseplatform\helengine.baseplatform.csproj" />
    <ProjectReference Include="$(HelEngineRoot)\engine\helengine.core\helengine.core.csproj" />
    <ProjectReference Include="$(HelEngineRoot)\engine\helengine.editor\helengine.editor.csproj" />
    <ProjectReference Include="$(HelEngineRoot)\engine\helengine.editor.windows\helengine.editor.windows.csproj" />
    <ProjectReference Include="$(HelEngineRoot)\engine\helengine.files\helengine.files.csproj" />
  </ItemGroup>
</Project>
